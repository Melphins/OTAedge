# Database connection
DATABASE_URL=postgres://user:password@localhost:5432/otaedge?sslmode=require

# JWT secret (minimum 32 characters for security)
JWT_SECRET=your-very-long-and-secure-secret-key-at-least-32-chars

# Application environment (development/production)
APP_ENV=development

# Optional: Metrics token for protecting /metrics endpoint
# When set, clients must provide X-Metrics-Token header matching this value
METRICS_TOKEN=your-metrics-token

# S3 / MinIO configuration (optional - if not set, falls back to local filesystem)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=otaedge-models

# Local storage path (used when S3 not configured or as fallback)
MODEL_STORAGE_PATH=./storage/models
